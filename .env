# Database
DATABASE_URL=postgresql+asyncpg://pharmalens:pharmalens@postgres:5432/pharmalens

# Redis
REDIS_URL=redis://redis:6379/0

# API settings
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Optional: Anthropic API for Phase 3+ drug profiling
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Twitter API for Phase 3+ KOL sentiment
# TWITTER_BEARER_TOKEN=...

# Optional: PubMed API key (raises rate limit from 3 to 10 req/sec)
# PUBMED_API_KEY=...

# Optional: Email alerts (Phase 3+)
# SENDGRID_API_KEY=...
# ALERT_FROM_EMAIL=alerts@your-domain.com
